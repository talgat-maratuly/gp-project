# GP Service — скопируйте в .env.local или задайте в Vercel → Environment Variables
VITE_API_URL=https://api.gp-service.kz/api
VITE_GP_DEMO=false
# Тестовый режим: LocalStorage-аккаунты при недоступности БД (MVP UI testing)
VITE_GP_TEST_MODE=true
# Demo hub (cross-app LocalStorage sync): npm run demo:hub
VITE_GP_DEMO_HUB=http://127.0.0.1:5190
